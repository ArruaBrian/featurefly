{
  "name": "featurefly",
  "version": "0.3.0",
  "description": "Lightweight, framework-agnostic Feature Flags SDK with built-in caching, retry, circuit breaker, targeting, A/B testing, and real-time streaming",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "dev": "tsc --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "docs": "typedoc",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "featurefly",
    "sdk",
    "typescript",
    "framework-agnostic",
    "feature-management",
    "ab-testing",
    "gradual-rollout",
    "circuit-breaker",
    "targeting",
    "streaming",
    "edge-evaluation",
    "react-hooks",
    "vue-composables"
  ],
  "author": "Arrua Platform Team",
  "license": "MIT",
  "homepage": "https://github.com/ArruaBrian/featurefly#readme",
  "bugs": {
    "url": "https://github.com/ArruaBrian/featurefly/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArruaBrian/featurefly.git"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.0.0",
    "msw": "^2.13.3",
    "node-fetch": "^3.3.2",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "vue": "^3.5.29"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/esm/react/index.d.ts",
        "default": "./dist/esm/react/index.js"
      },
      "require": {
        "types": "./dist/cjs/react/index.d.ts",
        "default": "./dist/cjs/react/index.js"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/esm/vue/index.d.ts",
        "default": "./dist/esm/vue/index.js"
      },
      "require": {
        "types": "./dist/cjs/vue/index.d.ts",
        "default": "./dist/cjs/vue/index.js"
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "msw": {
    "workerDirectory": [
      "src/shared/__tests__/integration"
    ]
  }
}